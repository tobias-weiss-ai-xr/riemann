{
  "name": "Riemann Research — GNN × Number Theory",
  "build": {
    "dockerfile": "../research/Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--gpus", "all",
    "--shm-size", "16g",
    "--ipc=host"
  ],
  "hostRequirements": {
    "gpu": true,
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8888, 7474, 7687, 6006],
  "containerEnv": {
    "PYTHONPATH": "/workspace/scripts:/workspace/knowledge-graph/scripts",
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"
  },
  "postCreateCommand": "pip install -e /workspace/scripts 2>/dev/null || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.jupyter-renderers",
        "charliermarsh.ruff",
        "ms-python.vscode-pylance",
        "tamasfe.even-better-toml",
        "docker.docker",
        "neo4j-extensions.vscode-neo4j"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.extraPaths": ["/workspace/scripts", "/workspace/knowledge-graph/scripts"],
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["scripts"],
        "[python]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      }
    }
  }
}
